# --- Turso / libSQL ---
# For LOCAL development you can use a plain SQLite file (no Turso account needed):
#   TURSO_DATABASE_URL=file:local.db
#
# For PRODUCTION (Vercel), create a Turso database and paste its credentials:
#   turso db create humaine
#   turso db show humaine --url
#   turso db tokens create humaine
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# Secret key that unlocks the /admin moderation queue. Pick a long random
# string. Required to use /admin (approve/unapprove/delete signatures+messages).
ADMIN_SECRET=

# --- Manifesto film ---
# Public URL of the manifesto video, self-hosted on Vercel Blob (store:
# humaine-film). The homepage "Watch the film" section is hidden when unset.
# To publish a new cut: compress to web-optimized H.264, then
#   vercel blob put film.mp4 --pathname humaine-film-vN.mp4 --allow-overwrite
# and update this URL (locally and in Vercel project env vars).
NEXT_PUBLIC_MANIFESTO_VIDEO_URL=
