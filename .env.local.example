# --- Turso / libSQL ---
# For LOCAL development you can use a plain SQLite file (no Turso account needed):
#   TURSO_DATABASE_URL=file:local.db
#
# For PRODUCTION (Vercel), create a Turso database and paste its credentials:
#   turso db create humaine
#   turso db show humaine --url
#   turso db tokens create humaine
TURSO_DATABASE_URL=file:local.db
TURSO_AUTH_TOKEN=

# Secret key that unlocks the /admin moderation queue. Pick a long random
# string. Required to use /admin (approve/unapprove/delete signatures+messages).
ADMIN_SECRET=
